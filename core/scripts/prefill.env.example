# NixPI wizard prefill — copy to core/scripts/prefill.env and fill in values.
# just vm will stage it automatically; any variable left unset will still prompt.

PREFILL_NETBIRD_KEY=your-netbird-setup-key-here
PREFILL_NAME="Your Name"
PREFILL_EMAIL="you@example.com"
PREFILL_USERNAME=yourlocalusername
# Primary user password used for prefilled unattended test/dev installs.
# This is written into ~/.nixpi/prefill.env during installation.
PREFILL_PRIMARY_PASSWORD=yourpassword
