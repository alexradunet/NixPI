include /etc/sway/config

# Bloom: expose the current sway session over VNC for NetBird mesh access.
# Accessible from any NetBird peer. Connect with any VNC client to port 5901.
exec_always --no-startup-id sh -lc 'pkill -x wayvnc >/dev/null 2>&1 || true; wayvnc 0.0.0.0 5901'

# Bloom: open one terminal on login and start Pi.
# Falls back to an interactive shell if `pi` exits or is unavailable.
exec --no-startup-id foot --title "Bloom Pi" sh -lc 'if command -v pi >/dev/null 2>&1; then pi; else exec bash; fi'

# Bloom: launch browser
bindsym $mod+backslash exec chromium
