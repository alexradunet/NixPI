// Nazar private browser terminal.
// Served by systemd service nazar-zellij-web on 127.0.0.1:8082
// and exposed only through the NetBird-private nginx vhost at /zellij/.
web_server_ip "127.0.0.1"
web_server_port 8082
web_sharing "on"
show_release_notes false

web_client {
    font "monospace"
    base_url "/zellij/"
}
