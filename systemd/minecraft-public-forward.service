[Unit]
Description=Public Minecraft and voice-chat forwards to VM 110
After=network-online.target pve-firewall.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/bash /usr/local/sbin/minecraft-public-forward start
ExecStop=/bin/bash /usr/local/sbin/minecraft-public-forward stop

[Install]
WantedBy=multi-user.target
