#!/usr/bin/env bash
set -euo pipefail
WARN=${NAZAR_DISK_WARN_PERCENT:-80}
CRIT=${NAZAR_DISK_CRIT_PERCENT:-90}
HOST=$(hostname -f 2>/dev/null || hostname)
TMP=$(mktemp)
trap 'rm -f "$TMP"' EXIT

# Check real local filesystems, ignore tmpfs/devtmpfs/overlay-style pseudo filesystems.
df -P -x tmpfs -x devtmpfs -x squashfs -x overlay | awk 'NR>1 {gsub(/%/,"",$5); print $1, $6, $5, $4}' > "$TMP"

problems=()
while read -r fs mount used avail; do
  [[ -z "${fs:-}" ]] && continue
  if (( used >= CRIT )); then problems+=("ERROR ${mount} ${used}% free_kb=${avail} fs=${fs}")
  elif (( used >= WARN )); then problems+=("WARNING ${mount} ${used}% free_kb=${avail} fs=${fs}")
  fi
done < "$TMP"

((${#problems[@]})) || exit 0
severity=warning
for p in "${problems[@]}"; do [[ "$p" == ERROR* ]] && severity=error; done

{
  echo "Disk usage threshold crossed on ${HOST}."
  echo
  echo "Thresholds: warning=${WARN}% critical=${CRIT}%"
  echo
  printf '%s\n' "${problems[@]}"
  echo
  echo "df -h output"
  echo "-----------"
  df -h -x tmpfs -x devtmpfs -x squashfs -x overlay
  echo
  echo "Proxmox storage"
  echo "---------------"
  pvesm status 2>&1 || true
} | /usr/local/sbin/nazar-proxmox-notify --severity "$severity" --source disk --type nazar-disk-alert --summary "Disk usage threshold crossed on ${HOST}" >/dev/null 2>&1
