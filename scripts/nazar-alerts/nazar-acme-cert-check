#!/usr/bin/env bash
set -euo pipefail
CERT=${1:-/etc/pve/local/pveproxy-ssl.pem}
WARN_DAYS=${NAZAR_CERT_WARN_DAYS:-21}
CRIT_DAYS=${NAZAR_CERT_CRIT_DAYS:-7}
HOST=$(hostname -f 2>/dev/null || hostname)

if [[ ! -r "$CERT" ]]; then
  echo "Certificate not readable: $CERT" | /usr/local/sbin/nazar-proxmox-notify --severity error --source acme --type nazar-acme-alert --summary "ACME certificate missing/unreadable: $CERT" >/dev/null 2>&1
  exit 2
fi

end_epoch=$(openssl x509 -in "$CERT" -noout -enddate | cut -d= -f2- | xargs -I{} date -d "{}" +%s)
now_epoch=$(date +%s)
days_left=$(( (end_epoch - now_epoch) / 86400 ))
not_after=$(openssl x509 -in "$CERT" -noout -enddate | cut -d= -f2-)
subject=$(openssl x509 -in "$CERT" -noout -subject | sed 's/^subject=//')
issuer=$(openssl x509 -in "$CERT" -noout -issuer | sed 's/^issuer=//')

if (( days_left <= CRIT_DAYS )); then severity=error; elif (( days_left <= WARN_DAYS )); then severity=warning; else exit 0; fi

{
  echo "Proxmox ACME/TLS certificate is nearing expiry on ${HOST}."
  echo
  echo "Certificate: $CERT"
  echo "Subject: $subject"
  echo "Issuer: $issuer"
  echo "Not after: $not_after"
  echo "Days left: $days_left"
  echo
  echo "Suggested checks:"
  echo "  pvenode cert info"
  echo "  journalctl -u pve-daily-update.service --since '7 days ago' --no-pager"
  echo "  pvenode acme cert order"
} | /usr/local/sbin/nazar-proxmox-notify --severity "$severity" --source acme --type nazar-acme-alert --summary "ACME certificate expires in ${days_left} days" >/dev/null 2>&1
