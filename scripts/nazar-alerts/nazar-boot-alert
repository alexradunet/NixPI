#!/usr/bin/env bash
set -euo pipefail
HOST=$(hostname -f 2>/dev/null || hostname)
BOOT_ID=$(cat /proc/sys/kernel/random/boot_id 2>/dev/null || echo unknown)
UPTIME=$(uptime -p 2>/dev/null || true)
LAST=$(last -x reboot shutdown 2>/dev/null | head -n 12 || true)

{
  echo "Nazar host booted or alert service started."
  echo
  echo "Host: $HOST"
  echo "Boot ID: $BOOT_ID"
  echo "Uptime: $UPTIME"
  echo
  echo "Recent reboot/shutdown history"
  echo "-------------------------------"
  echo "$LAST"
  echo
  echo "Failed units"
  echo "------------"
  systemctl --failed --no-pager 2>&1 || true
} | /usr/local/sbin/nazar-proxmox-notify --severity notice --source boot --type nazar-boot-alert --summary "Nazar host booted: ${HOST}" >/dev/null 2>&1
