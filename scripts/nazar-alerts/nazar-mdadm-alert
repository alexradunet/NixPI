#!/usr/bin/env bash
set -euo pipefail

EVENT=${1:-UnknownEvent}
ARRAY=${2:-unknown-array}
COMPONENT=${3:-}
HOST=$(hostname -f 2>/dev/null || hostname)
NOW=$(date --iso-8601=seconds)

SEVERITY="warning"
case "$EVENT" in
  TestMessage|RebuildStarted|RebuildFinished|SparesMissing)
    SEVERITY="notice"
    ;;
  Fail|FailSpare|DegradedArray|DeviceDisappeared|NewArray|MoveSpare)
    SEVERITY="error"
    ;;
esac

SUMMARY="RAID ${EVENT}: ${ARRAY}"
if [[ -n "$COMPONENT" ]]; then
  SUMMARY+=" (${COMPONENT})"
fi

DETAIL=""
if [[ -e "$ARRAY" ]]; then
  DETAIL=$(mdadm --detail "$ARRAY" 2>&1 || true)
fi

{
  echo "mdadm RAID monitor event on ${HOST}"
  echo
  echo "Time: ${NOW}"
  echo "Event: ${EVENT}"
  echo "Array: ${ARRAY}"
  if [[ -n "$COMPONENT" ]]; then
    echo "Component: ${COMPONENT}"
  fi
  echo
  echo "/proc/mdstat"
  echo "------------"
  cat /proc/mdstat 2>&1 || true
  if [[ -n "$DETAIL" ]]; then
    echo
    echo "mdadm --detail ${ARRAY}"
    echo "-------------------------"
    echo "$DETAIL"
  fi
} | /usr/local/sbin/nazar-proxmox-notify \
      --severity "$SEVERITY" \
      --source mdadm \
      --type nazar-raid-alert \
      --summary "$SUMMARY" >/dev/null 2>&1
