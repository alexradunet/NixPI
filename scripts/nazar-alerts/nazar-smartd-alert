#!/usr/bin/env bash
set -euo pipefail

HOST=$(hostname -f 2>/dev/null || hostname)
NOW=$(date --iso-8601=seconds)
FAILTYPE=${SMARTD_FAILTYPE:-Unknown}
DEVICE=${SMARTD_DEVICESTRING:-${SMARTD_DEVICE:-unknown-device}}
SUBJECT=${SMARTD_SUBJECT:-SMART alert on ${HOST}: ${DEVICE} ${FAILTYPE}}
FULLMESSAGE=${SMARTD_FULLMESSAGE:-}

# If smartd invoked us in mail-compatible mode, consume stdin as a fallback body.
if [[ -z "$FULLMESSAGE" ]] && ! [ -t 0 ]; then
  FULLMESSAGE=$(cat || true)
fi

SEVERITY="warning"
case "$FAILTYPE" in
  EmailTest)
    SEVERITY="notice"
    ;;
  Health|FailedHealthCheck|FailedReadSmartData|FailedReadSmartErrorLog|FailedReadSmartSelfTestLog|FailedOpenDevice)
    SEVERITY="error"
    ;;
esac

SUMMARY="$SUBJECT"

{
  echo "smartd disk monitor alert on ${HOST}"
  echo
  echo "Time: ${NOW}"
  echo "Fail type: ${FAILTYPE}"
  echo "Device: ${DEVICE}"
  if [[ -n "${SMARTD_DEVICEINFO:-}" ]]; then
    echo "Device info: ${SMARTD_DEVICEINFO}"
  fi
  if [[ -n "${SMARTD_MESSAGE:-}" ]]; then
    echo "Message: ${SMARTD_MESSAGE}"
  fi
  if [[ -n "${SMARTD_TFIRST:-}" ]]; then
    echo "First seen: ${SMARTD_TFIRST}"
  fi
  if [[ -n "${SMARTD_PREVCNT:-}" ]]; then
    echo "Previous count: ${SMARTD_PREVCNT}"
  fi
  if [[ -n "${SMARTD_NEXTDAYS:-}" ]]; then
    echo "Next reminder days: ${SMARTD_NEXTDAYS}"
  fi
  echo
  echo "Full smartd message"
  echo "-------------------"
  if [[ -n "$FULLMESSAGE" ]]; then
    echo "$FULLMESSAGE"
  else
    echo "No SMARTD_FULLMESSAGE/stdin body was provided."
  fi
} | /usr/local/sbin/nazar-proxmox-notify \
      --severity "$SEVERITY" \
      --source smartd \
      --type nazar-smart-alert \
      --summary "$SUMMARY" >/dev/null 2>&1
