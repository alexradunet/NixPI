#!/usr/bin/env bash
set -euo pipefail

iptables=/usr/sbin/iptables
netbird_if=wt0
vm_if=vmbr1
vm_ip=10.10.10.30
minecraft_port=25565
voice_port=24454

add_rule() {
  local table=$1
  shift
  if [[ "$table" == filter ]]; then
    "$iptables" -C "$@" 2>/dev/null || "$iptables" -I "$@"
  else
    "$iptables" -t "$table" -C "$@" 2>/dev/null || "$iptables" -t "$table" -I "$@"
  fi
}

delete_rule() {
  local table=$1
  shift
  if [[ "$table" == filter ]]; then
    "$iptables" -D "$@" 2>/dev/null || true
  else
    "$iptables" -t "$table" -D "$@" 2>/dev/null || true
  fi
}

add_forward() {
  local proto=$1
  local port=$2

  add_rule nat PREROUTING -i "$netbird_if" -p "$proto" --dport "$port" \
    -j DNAT --to-destination "$vm_ip:$port"
  add_rule filter FORWARD -i "$netbird_if" -o "$vm_if" -p "$proto" -d "$vm_ip" \
    --dport "$port" -m conntrack --ctstate NEW,ESTABLISHED,RELATED -j ACCEPT
  add_rule filter FORWARD -i "$vm_if" -o "$netbird_if" -p "$proto" -s "$vm_ip" \
    --sport "$port" -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
}

delete_forward() {
  local proto=$1
  local port=$2

  delete_rule nat PREROUTING -i "$netbird_if" -p "$proto" --dport "$port" \
    -j DNAT --to-destination "$vm_ip:$port"
  delete_rule filter FORWARD -i "$netbird_if" -o "$vm_if" -p "$proto" -d "$vm_ip" \
    --dport "$port" -m conntrack --ctstate NEW,ESTABLISHED,RELATED -j ACCEPT
  delete_rule filter FORWARD -i "$vm_if" -o "$netbird_if" -p "$proto" -s "$vm_ip" \
    --sport "$port" -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
}

case "${1:-}" in
  start)
    add_forward tcp "$minecraft_port"
    # Simple Voice Chat plugin.
    add_forward udp "$voice_port"
    ;;
  stop)
    delete_forward tcp "$minecraft_port"
    delete_forward udp "$voice_port"
    ;;
  *)
    echo "Usage: $0 {start|stop}" >&2
    exit 2
    ;;
esac
