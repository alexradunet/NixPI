#!/usr/bin/env bash
set -euo pipefail

# Idempotently create/configure the Linux `alex` admin user on the Debian/Proxmox
# host. This manages host shell access only. It does not modify Proxmox VE realm
# users such as alex@pve or root@pam.

if [[ $EUID -ne 0 ]]; then
  echo "Run as root on nazar." >&2
  exit 1
fi

repo_root=${NAZAR_REPO_ROOT:-/root/nazar}
admin_keys_file="$repo_root/nix/users/admin-keys.nix"
if [[ ! -r "$admin_keys_file" ]]; then
  echo "Missing admin keys file: $admin_keys_file" >&2
  exit 1
fi

if ! getent group sudo >/dev/null; then
  echo "Missing sudo group; refusing to continue." >&2
  exit 1
fi

if ! id alex >/dev/null 2>&1; then
  useradd --create-home --shell /bin/bash --groups sudo --comment "Nazar host admin" alex
else
  usermod --shell /bin/bash --append --groups sudo alex
  mkdir -p /home/alex
  chown alex:alex /home/alex
fi

# Keep the Linux password locked for normal host shell. SSH/NetBird access is
# key/identity based; root remains the console/rescue password break-glass path.
passwd -l alex >/dev/null || true

install -d -m 0700 -o alex -g alex /home/alex/.ssh
python3 - "$admin_keys_file" >/home/alex/.ssh/authorized_keys <<'PY'
import re
import sys
from pathlib import Path

text = Path(sys.argv[1]).read_text()
keys = []
for match in re.finditer(r'"(ssh-[^"]+)"', text):
    key = match.group(1)
    if key not in keys:
        keys.append(key)
if not keys:
    raise SystemExit("no SSH public keys found")
print("\n".join(keys))
PY
chown alex:alex /home/alex/.ssh/authorized_keys
chmod 0600 /home/alex/.ssh/authorized_keys

cat >/etc/sudoers.d/90-nazar-alex <<'SUDOERS'
# Managed by /root/nazar/scripts/proxmox/ensure-host-alex-user.
# `alex` is the daily host shell admin; root remains break-glass.
alex ALL=(ALL:ALL) NOPASSWD:ALL
SUDOERS
chown root:root /etc/sudoers.d/90-nazar-alex
chmod 0440 /etc/sudoers.d/90-nazar-alex
visudo -cf /etc/sudoers.d/90-nazar-alex >/dev/null

printf 'Configured Linux admin user alex on nazar.\n'
